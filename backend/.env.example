# Server
PORT=4000
FRONTEND_ORIGIN=https://your-domain-on-hostinger.com

# Postgres (docker-compose service name "db" if using the provided compose file)
DATABASE_URL=postgresql://vastu:vastu@db:5432/vastu?schema=public

# Admin API access (for GET /api/leads)
ADMIN_TOKEN=change-this-to-a-long-random-string

# Razorpay (from Razorpay Dashboard > Settings > API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
MASTERCLASS_PRICE_PAISE=9900

# MSG91 WhatsApp (from MSG91 dashboard > WhatsApp)
MSG91_AUTH_KEY=
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WHATSAPP_TEMPLATE_NAME=
MSG91_WHATSAPP_NAMESPACE=

# Google Sheets mirror (see backend/README.md for service account setup)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_FUNNEL_TAB=Funnel
GOOGLE_SHEETS_CONFIRMED_TAB=Confirmed
